---
import Countdown from "@/components/Countdown.vue"
import Layout from "@/layouts/Layout.astro"
import { currentEvent } from "@/util/event.ts"
import DoorButton from "@/components/DoorButton.vue"
import { services, getClients } from "@/util/lan.ts"

const now = Date.now()
const hasEnded = currentEvent.endDateTime.getTime() < now
const hasStarted = !hasEnded && currentEvent.startDateTime.getTime() <= now

const clients = getClients()
const currentClient = clients.all.find(
  ({ ip }) => ip === (Astro.request.headers.get("x-real-ip") ?? Astro.clientAddress),
)
---

<Layout>
  <div class="container">
    {
      !hasStarted && !hasEnded && (
        <p>
          La RastaLAN débute dans
          <br />
          <Countdown date={currentEvent.startDateTime} client:only />
        </p>
      )
    }
    {hasStarted && !process.env.LAN_MODE && <p>La RastaLAN a débuté&nbsp;!</p>}
    {
      hasEnded && (
        <>
          <p>La RastaLAN est terminée.</p>
          <p>À dans six mois pour la prochaine LAN&nbsp;!</p>
        </>
      )
    }

    {
      hasStarted && !!process.env.LAN_MODE && (
        <div class="local-info">
          <p>Bienvenue à la RastaLAN&nbsp;!</p>
          {currentClient !== undefined && (
            <>
              <div class="item">
                <span>Nom d'hôte</span>
                <span>
                  <code>{currentClient.name}</code>
                </span>
              </div>
              <div class="item">
                <span>Adresse IP</span>
                <span>
                  <code>{currentClient.ip}</code>
                </span>
              </div>
              <div class="item">
                <span>Connexion</span>
                <span>
                  {currentClient.iface === "cable" ? <code>Ethernet</code> : <code>Wi-Fi ({currentClient.iface})</code>}
                </span>
              </div>
              <div class="spacer" />
            </>
          )}

          {services.map(service => (
            <div class="item">
              <span>{service.name}</span>
              <span>
                {service.web ? (
                  <a href={service.web} target={service.web.startsWith("https://") ? "_blank" : undefined}>
                    <code>{service.uri}</code>
                  </a>
                ) : (
                  <code>{service.uri}</code>
                )}
              </span>
            </div>
          ))}

          <a class="online" href="/joueurs">
            <span class="icon">🖥️</span> {clients.wired.length} joueurs connectés
          </a>
        </div>
      )
    }

    {hasStarted && <DoorButton client:load>Ouvrir la porte</DoorButton>}
    {
      !hasEnded && (
        <a class="button" href="/inscription">
          Je m'inscris
        </a>
      )
    }
    <a class="button" href="/participants">Liste des participants</a>
  </div>
</Layout>

<style>
  .container {
    margin: auto;

    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .countdown {
    font-size: 3.5rem;
  }

  button,
  .button {
    max-width: 300px;
    margin: auto;
  }

  .local-info {
    background-color: #3008;
    width: 420px;
    max-width: 100%;
    margin: auto;
    padding: 0.5em 1em;
    border-radius: 0.5em;
    display: flex;
    flex-direction: column;
    gap: 0.2em;

    p {
      margin-top: 0;
    }

    .online {
      align-self: center;
      display: flex;
      gap: 0.5em;
      text-decoration: none;
      font-size: 0.8em;
      margin-top: 1em;
      background-color: #200b;
      padding: 0.3em 0.6em;
      border-radius: 2em;

      &:hover {
        background-color: #200f;
      }

      .icon {
        font-size: 0.8em;
      }
    }

    .item {
      text-align: left;
      font-size: 0.8em;
      display: flex;
      gap: 0.5em;
      align-items: center;
      justify-content: space-between;
      padding: 0.1em 0;
    }

    .spacer {
      padding: 0.5em 0;
    }
  }

  @media (max-width: 550px) {
    .countdown {
      font-size: 3rem;
    }
  }

  @media (max-width: 400px) {
    .countdown {
      font-size: 2.25rem;
    }

    .local-info .item {
      font-size: 0.75em;
    }
  }

  code {
    display: inline-block;
  }
</style>
